# Supabase — get these from your Supabase project → Settings → API
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# API backend URL — set to your deployed API origin (Railway, Render, etc.)
# Leave empty to use relative /api paths (only works with a proxy in dev)
VITE_API_URL=https://your-api.railway.app

# WebSocket URL — same host as the API, ws:// or wss://
VITE_WS_URL=wss://your-api.railway.app/ws

# Dev-only: bypass Supabase auth during local development
# DO NOT set this in production / Vercel env vars
# VITE_DEV_BYPASS_AUTH=true
