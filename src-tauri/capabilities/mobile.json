{
  "$schema": "../node_modules/@tauri-apps/cli/schema/acl/capability.json",
  "identifier": "mobile",
  "description": "SANCTION mobile (Android) capabilities",
  "platforms": ["android"],
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-open",
    "shell:allow-execute",
    "shell:allow-spawn",
    "dialog:allow-open",
    "dialog:allow-save",
    "os:allow-platform",
    "os:allow-os-type"
  ]
}
